				Comment: "Documentation for parameter p_previousSolutionY";
				IndexDomain: (i_indv,i_particle);
				Text: "Y coordinates of the previous solution for the individual.";
			}
			Parameter p_currentSolutionVelocityX {
				Comment: "Documentation for parameter p_currentSolutionVelocityX";
				IndexDomain: (i_indv,i_particle);
				Text: "X velocity of the current solution for the individual.";
			}
			Parameter p_currentSolutionVelocityY {
				Comment: "Documentation for parameter p_currentSolutionVelocityY";
				IndexDomain: (i_indv,i_particle);
				Text: "Y velocity of the current solution for the individual.";
			}
			Parameter p_previousSolutionVelocityX {
				Comment: "Documentation for parameter p_previousSolutionVelocityX";
				IndexDomain: (i_indv,i_particle);
				Text: "X velocity of the previous solution for the individual.";
			}
			Parameter p_previousSolutionVelocityY {
				Comment: "Documentation for parameter p_previousSolutionVelocityY";
				IndexDomain: (i_indv,i_particle);
				Text: "Y velocity of the previous solution for the individual.";
			}
			Parameter p_demand {
				Comment: "Documentation for parameter p_demand";
				IndexDomain: (i_loc,i_indv);
			}
			Parameter p_range {
				Comment: "Documentation for parameter p_range";
				IndexDomain: (i_loc,i_indv);
			}
			Parameter p_bestGlobalSolutionCost {
				Comment: "Documentation for parameter p_bestGlobalSolutionCost";
				Default: 999999999;
			}
			ElementParameter p_bestGlobalAllocation {
				Comment: "Documentation for elementparameter p_bestGlobalAllocation";
