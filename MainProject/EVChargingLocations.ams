				Index: i_n_clos;
				Definition: ElementRange(1, p_def_nClosest, 1);
			}
			ElementParameter ep_nClosestLocation {
				Comment: "Documentation for elementparameter ep_nClosestLocation";
				IndexDomain: (i_loc,i_indv);
				Range: s_def_particles;
			}
			ElementParameter ep_globalBestAllocations {
				Comment: "Documentation for elementparameter ep_globalBestAllocations";
				IndexDomain: (i_loc,i_indv);
				Range: s_def_particles;
			}
		}
		DeclarationSection KNN_Auxiliar_Parameters {
			Comment: "Documentation for declarationsection KNN_Auxiliar_Parameters";
			Parameter p_distances {
				Comment: "Documentation for parameter p_distances";
