			}
			Parameter p_totalMaintenanceCost {
				Comment: "Documentation for parameter p_totalMaintenanceCost";
				IndexDomain: i_indv;
			}
			Parameter p_totalDrivingCost {
				Comment: "Documentation for parameter p_totalDrivingCost";
				IndexDomain: (i_indv);
			}
			Parameter p_totalChargingCost {
				Comment: "Documentation for parameter p_totalChargingCost";
				IndexDomain: (i_indv);
			}
			Parameter p_totalPenaltyCost {
				Comment: "Documentation for parameter p_totalPenaltyCost";
