## ams_version=1.0

Model Main_EVChargingLocations {
	Comment: "Documentation for model Main_EVChargingLocations";
	Section Data_Model {
		Comment: "Documentation for section Data_Model";
		Section Quantities_and_Units {
			Comment: {
				"This section contains all the units and quantities that are added automatically by AIMMS.
				It is recommended to declare all your quantities here."
			}
			Quantity SI_Time_Duration {
				BaseUnit: s;
				Conversions: minute->s : #-># * 60;
				Comment: {
					"Expresses the value for the duration of periods.
					
					The unit s has been added automatically because it is a required unit for AimmsWebUI.
					
					The unit minute has been added automatically because it is a required unit for AimmsWebUI."
				}
			}
		}
		DeclarationSection Master_Data {
			Comment: "Documentation for declarationsection Master_Data";
			Set s_def_particles {
				Comment: "Documentation for set s_def_particles";
				Text: "Set of particles in each individual.";
				Index: i_particle;
				Definition: {
					ElementRange(
						From    :  1, 
						To      :  p_numberParticles, 
						Prefix  :  "p")
				}
				webui::AnnotationsIdentifier: ui::sp_def_stationNodeColor(i_particle);
			}
			Set s_def_generations {
				Comment: "Documentation for set s_def_generations";
				Text: "Number of generations the algorithm runs for.";
				Index: i_gen;
				Definition: {
					ElementRange(
						From    :  1, 
						To      :  p_numberGenerations, 
						Prefix  :  "g")
				}
			}
			Set s_def_individuals {
				Comment: "Documentation for set s_def_individuals";
				Text: "Set of inidivuals in the population.";
				Index: i_indv;
				Parameter: ep_individual;
				Definition: {
					ElementRange(
						From    :  1, 
						To      :  p_populationSize, 
						Prefix  :  "i")
				}
			}
			Set s_locations {
				Comment: "Documentation for set s_locations";
				Text: "Set of locations.";
				Index: i_loc1;
				OrderBy: sum(i_indv, p_demand(i_loc1,i_indv));
				webui::AnnotationsIdentifier: ui::sp_def_evNodeColor(i_loc);
			}
			Set s_chargers {
				Comment: "Documentation for set s_chargers";
				Index: i_charger;
				Definition: {
					ElementRange(
						From    :  1, 
						To      :  p_maxNumberChargersPerStation)
				}
			}
			Index i_loc {
				Comment: "Documentation for index i_loc";
				Range: s_locations;
				dex::ColumnName: Location;
			}
			Parameter p_y {
				Comment: "Documentation for parameter p_y";
				IndexDomain: i_loc;
				dex::ColumnName: Y;
				dex::Dataset: DefaultData;
				dex::TableName: Locations;
			}
			Parameter p_x {
				Comment: "Documentation for parameter p_x";
				IndexDomain: i_loc;
				dex::ColumnName: X;
				dex::Dataset: DefaultData;
				dex::TableName: Locations;
			}
			Parameter p_latitude {
				Comment: "Documentation for parameter p_latitude";
				IndexDomain: i_loc;
			}
			Parameter p_longitude {
				Comment: "Documentation for parameter p_longitude";
				IndexDomain: i_loc;
			}
			Parameter p_def_minLatitude {
				Definition: 39.722422;
				Comment: "data from Pennsylvania (https://www.latlong.net/)";
			}
			Parameter p_def_maxLatitude {
				Definition: 41.998439;
				Comment: "data from Pennsylvania (https://www.latlong.net/)";
			}
			Parameter p_def_minLongitude {
				Definition: -80.516914;
				Comment: "data from Pennsylvania (https://www.latlong.net/)";
			}
			Parameter p_def_maxLongitude {
				Definition: -74.023697;
				Comment: "data from Pennsylvania (https://www.latlong.net/)";
			}
		}
		DeclarationSection Control_Panel {
			Comment: "Documentation for declarationsection Control_Panel";
			Parameter p_maintenanceCost {
				Comment: "Documentation for parameter p_maintenanceCost";
				InitialData: 500;
			}
			Parameter p_constructionCost {
				Comment: "Documentation for parameter p_constructionCost";
				InitialData: 5000;
			}
			Parameter p_drivingCostPerMile {
				Comment: "Documentation for parameter p_drivingCostPerMile";
				InitialData: 0.2;
			}
			Parameter p_chargingCostPerHour {
				Comment: "Documentation for parameter p_chargingCostPerHour";
				InitialData: 0.5;
			}
			Parameter p_noAllocationPenalty {
				Comment: "Documentation for parameter p_noAllocationPenalty";
				InitialData: 5000;
			}
			Parameter p_maxNumberChargersPerStation {
				Comment: "Documentation for parameter p_maxNumberChargersPerStation";
				InitialData: 8;
			}
			Parameter p_meanVehicleRange {
				Comment: "Documentation for parameter p_meanVehicleRange";
				InitialData: 100;
			}
			Parameter p_maxVehicleRange {
				Comment: "Documentation for parameter p_maxVehicleRange";
				InitialData: 250;
			}
			Parameter p_minVehicleRange {
				Comment: "Documentation for parameter p_minVehicleRange";
				InitialData: 20;
			}
			Parameter p_chargingProbability {
				Comment: "Documentation for parameter p_chargingProbability";
			}
			Parameter p_numberParticles {
				Comment: "Documentation for parameter p_numberParticles";
				Text: "The number of particles in each individual.";
				Range: integer;
				InitialData: 400;
			}
			Parameter p_numberGenerations {
				Comment: "Documentation for parameter p_numberGenerations";
				InitialData: 50;
			}
			Parameter p_populationSize {
				Comment: "Documentation for parameter p_populationSize";
				Text: "Number of individuals in the population.";
				Range: integer;
				InitialData: 5;
			}
			Parameter p_inertiaComponent {
				Comment: "Documentation for parameter p_inertiaComponent";
				InitialData: 0.83;
			}
			Parameter p_cognitiveComponent {
				Comment: "Documentation for parameter p_cognitiveComponent";
				InitialData: 0.05;
			}
			Parameter p_socialComponent {
				Comment: "Documentation for parameter p_socialComponent";
				InitialData: 0.14;
			}
			Parameter p_initial_velocity {
				Comment: "Documentation for parameter p_initial_velocity";
				InitialData: 5;
			}
			Parameter p_spawn_region {
				Text: "Region in which particles each particle is spawned in an individual.";
				InitialData: 10;
				Comment: "Distance from an initial \'spawn\' location within which a particle can be initialized.";
			}
			Parameter p_def_nClosest {
				Comment: "Documentation for parameter p_def_nClosest";
				Range: integer;
				InitialData: 20;
			}
			Parameter p_def_distanceCutoff {
				Comment: "Documentation for parameter p_def_distanceCutoff";
				InitialData: 50;
			}
			Parameter p_evPerLocation {
				Comment: "Documentation for parameter p_evPerLocation";
				InitialData: 10;
			}
			Parameter p_lambda {
				Comment: "Documentation for parameter p_lambda";
				InitialData: 0.012;
			}
		}
	}
	Section PSO_Model {
		Comment: "This section contains procedures that align with the main operations within PSO.";
		DeclarationSection KNN_Declaration {
			Comment: "Documentation for declarationsection KNN_Declaration";
			Set s_def_nClosests {
				Comment: "Documentation for set s_def_nClosests";
