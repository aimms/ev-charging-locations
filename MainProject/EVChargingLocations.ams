			}
			Parameter p_bestGlobalSolutionNumberOfStations {
				Comment: "Documentation for parameter p_bestGlobalSolutionNumberOfStations";
				webui::FlagsIdentifier: ui::sp_def_readOnly;
			}
			Parameter p_bestGlobalSolutionTotalChargers {
				Comment: "Documentation for parameter p_bestGlobalSolutionTotalChargers";
			}
			Parameter p_bestGlobalSolutionMaintenanceCost {
				Comment: "Documentation for parameter p_bestGlobalSolutionMaintenanceCost";
				IndexDomain: i_particle;
			}
			Parameter p_bestGlobalSolutionConstructionCost {
				Comment: "Documentation for parameter p_bestGlobalSolutionConstructionCost";
				IndexDomain: i_particle;
			}
			Parameter p_bestGlobalSolutionDrivingCost {
				Comment: "Documentation for parameter p_bestGlobalSolutionDrivingCost";
				IndexDomain: i_particle;
				webui::FlagsIdentifier: ui::sp_def_readOnly;
			}
			Parameter p_bestGlobalSolutionChargerCost {
				Comment: "Documentation for parameter p_bestGlobalSolutionChargerCost";
				IndexDomain: i_particle;
				webui::FlagsIdentifier: ui::sp_def_readOnly;
			}
			Parameter p_bestGlobalSolutionTotalCost {
				Comment: "Documentation for parameter p_bestGlobalSolutionTotalCost";
				IndexDomain: i_particle;
			}
			Parameter p_bestGlobalSolutionNumberOfVehicles {
				Comment: "Documentation for parameter p_bestGlobalSolutionNumberOfVehicles";
				IndexDomain: i_particle;
				webui::FlagsIdentifier: ui::sp_def_readOnly;
			}
			Parameter p_bestGlobalSolutionNumberOfChargers {
				Comment: "Documentation for parameter p_bestGlobalSolutionNumberOfChargers";
