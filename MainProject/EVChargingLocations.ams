			}
			Parameter p_bestGlobalSolutionDistanceToStation {
				Comment: "Documentation for parameter p_bestGlobalSolutionDistanceToStation";
				IndexDomain: i_loc;
				webui::FlagsIdentifier: ui::sp_def_readOnly;
			}
			Parameter p_bestLocalSolutionCost {
				Comment: "Documentation for parameter p_bestLocalSolutionCost";
